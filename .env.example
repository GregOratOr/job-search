# .env.example
# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── LLM provider (ai_tailor.py, job_discovery.py) ─────────────────────────────
# anthropic | ollama | openai
# LLM_PROVIDER=ollama

# Default model for the active provider (overrides provider defaults below)
# LLM_MODEL=gemma4:12b

# ── Anthropic (cloud) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local, OpenAI-compatible — no agent harness required) ─────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=gemma4:12b
OLLAMA_API_KEY=ollama

# ── OpenAI-compatible (OpenAI, LM Studio, vLLM, etc.) ───────────────────────
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
