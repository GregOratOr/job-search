# ── Generated outputs (rebuild from tailoring files) ────────────────────────
resume/outputs/*.tex
resume/outputs/*.pdf
resume/outputs/*.aux
resume/outputs/*.log
resume/outputs/*.out
resume/outputs/*.toc
resume/outputs/*.fls
resume/outputs/*.fdb_latexmk
resume/outputs/*.synctex.gz
coverletter/outputs/*.tex
coverletter/outputs/*.pdf
coverletter/outputs/*.aux
coverletter/outputs/*.log
coverletter/outputs/*.out

# Keep the output directories themselves
!resume/outputs/.gitkeep
!coverletter/outputs/.gitkeep

